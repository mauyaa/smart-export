# Copy to .env.local for local development (gitignored via *.local).
# Base URL of the SmartExports FastAPI backend.
# - Leave unset to use the deployed default (https://smartexports-api.onrender.com)
# - Set to http://localhost:8000 if you're running the API locally
VITE_API_BASE=https://smartexports-api.onrender.com
